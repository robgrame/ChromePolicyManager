@inherits LayoutComponentBase

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">Chrome Policy Manager</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                       Color="Color.Inherit" OnClick="@(() => _isDarkMode = !_isDarkMode)" />
    </MudAppBar>
    
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="@DrawerVariant.Mini" OpenMiniOnHover="true">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">CPM Admin</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="/catalog" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.LibraryBooks">Catalog</MudNavLink>
            <MudNavLink Href="/policies" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Policy">Policies</MudNavLink>
            <MudNavLink Href="/assignments" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Assignment">Assignments</MudNavLink>
            <MudNavLink Href="/devices" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Devices">Devices</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    
    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1976D2",
            Secondary = "#FF6F00",
            AppbarBackground = "#1976D2",
            TextPrimary = "#212121",
            TextSecondary = "#616161",
            TableLines = "#E0E0E0",
            TableStriped = "#F5F5F5"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#90CAF9",
            Secondary = "#FFB74D",
            TextPrimary = "#FFFFFFDE",
            TextSecondary = "#FFFFFF99",
            Surface = "#1E1E1E",
            Background = "#121212",
            TableLines = "#424242",
            TableStriped = "#2A2A2A"
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
