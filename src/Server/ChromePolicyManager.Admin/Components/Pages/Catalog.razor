@page "/catalog"
@using ChromePolicyManager.Admin.Services
@using ChromePolicyManager.Admin.Components.Pages.Dialogs
@inject PolicyApiClient Api
@inject IDialogService DialogService

<PageTitle>Policy Catalog - Chrome Policy Manager</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Class="mr-2" />
    Chrome Policy Catalog
</MudText>

@* Stats banner *@
@if (_stats is not null)
{
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudGrid>
            <MudItem xs="12" sm="3">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Template Version</MudText>
                <MudText Typo="Typo.h6">@_stats.TemplateVersion</MudText>
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Total Policies</MudText>
                <MudText Typo="Typo.h6">@_stats.TotalEntries</MudText>
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Mandatory</MudText>
                <MudText Typo="Typo.h6">@_stats.MandatoryPolicies</MudText>
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Recommended</MudText>
                <MudText Typo="Typo.h6">@_stats.RecommendedPolicies</MudText>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Last Import</MudText>
                <MudText Typo="Typo.h6">@(_stats.LastImport?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</MudText>
            </MudItem>
        </MudGrid>
    </MudPaper>
}
else if (_stats is null && !_loading)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        No policies imported yet. Upload the Chrome ADMX template zip to populate the catalog.
    </MudAlert>
}

@* Import section *@
<MudExpansionPanels Class="mb-4">
    <MudExpansionPanel Text="Import ADMX Templates" Icon="@Icons.Material.Filled.Upload">
        <MudText Typo="Typo.body2" Class="mb-3">
            Import Chrome policy definitions from ADMX templates. Choose one method:
        </MudText>
        
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" Class="mb-4">
            @* Tab 1: Download from Google (recommended — avoids large file upload through SignalR) *@
            <MudTabPanel Text="Download from Google" Icon="@Icons.Material.Filled.CloudDownload">
                <MudText Typo="Typo.body2" Class="mb-3 mt-3">
                    The server downloads the latest Chrome ADMX templates directly from Google Enterprise.
                    This is the recommended method (avoids 113MB upload through the browser).
                </MudText>
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="_importVersion" Label="Version Label" Placeholder="e.g. 136.0.7103.48" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudSelect @bind-Value="_importMode" Label="Import Mode" Variant="Variant.Outlined">
                            <MudSelectItem Value="@("full")">Full (replace all)</MudSelectItem>
                            <MudSelectItem Value="@("diff")">Differential (delta only)</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="3" Class="d-flex align-end">
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(_importing)"
                                   OnClick="ImportFromUrlAsync" StartIcon="@Icons.Material.Filled.Download">
                            @if (_importing)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <text>Downloading...</text>
                            }
                            else
                            {
                                <text>Import from Google</text>
                            }
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            @* Tab 2: Manual file upload (fallback for air-gapped environments) *@
            <MudTabPanel Text="Upload ZIP" Icon="@Icons.Material.Filled.UploadFile">
                <MudText Typo="Typo.body2" Class="mb-3 mt-3">
                    Upload <code>policy_templates.zip</code> from
                    <MudLink Href="https://chromeenterprise.google/browser/download/#manage-policies-tab" Target="_blank">
                        Chrome Enterprise
                    </MudLink>. For air-gapped environments only.
                </MudText>
                <MudGrid>
                    <MudItem xs="12" sm="5">
                        <MudFileUpload T="IBrowserFile" Accept=".zip" FilesChanged="OnFileSelected" MaximumFileCount="1">
                            <ActivatorContent>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload">
                                    Select ZIP File
                                </MudButton>
                            </ActivatorContent>
                        </MudFileUpload>
                        @if (_selectedFile is not null)
                        {
                            <MudText Typo="Typo.body2" Class="mt-2">Selected: @_selectedFile.Name (@((_selectedFile.Size / 1024 / 1024).ToString("F1")) MB)</MudText>
                        }
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudTextField @bind-Value="_importVersion" Label="Version Label" Placeholder="e.g. 136.0.7103.48" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="2">
                        <MudSelect @bind-Value="_importMode" Label="Mode" Variant="Variant.Outlined">
                            <MudSelectItem Value="@("full")">Full</MudSelectItem>
                            <MudSelectItem Value="@("diff")">Diff</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="2" Class="d-flex align-end">
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(_selectedFile is null || _importing)"
                                   OnClick="ImportAsync" StartIcon="@Icons.Material.Filled.DataObject">
                            @if (_importing)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <text>Importing...</text>
                            }
                            else
                            {
                                <text>Import</text>
                            }
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        </MudTabs>

        @if (!string.IsNullOrEmpty(_importError))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3" ShowCloseIcon="true" CloseIconClicked="() => _importError = null">
                ❌ @_importError
            </MudAlert>
        }
        @if (_importResult is not null)
        {
            <MudAlert Severity="Severity.Success" Class="mt-3">
                ✅ @_importResult.Message — @_importResult.Mandatory mandatory, @_importResult.Recommended recommended across @_importResult.Categories categories
            </MudAlert>
            @if (_importResult.Added > 0 || _importResult.Removed > 0 || _importResult.Updated > 0)
            {
                <MudAlert Severity="Severity.Info" Class="mt-2" Dense="true">
                    Delta: +@_importResult.Added added, ~@_importResult.Updated updated, -@_importResult.Removed removed
                </MudAlert>
            }
            @if (_importResult.Warnings.Count > 0)
            {
                <MudAlert Severity="Severity.Warning" Class="mt-2">
                    @_importResult.Warnings.Count warning(s) during import
                </MudAlert>
            }
        }
    </MudExpansionPanel>
</MudExpansionPanels>

@* Filters *@
@if (_entries.Count > 0 || _loading)
{
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_searchText" Label="Search policies" Placeholder="e.g. SafeBrowsing, password..."
                              Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true" DebounceInterval="300" TextChanged="OnSearchChanged" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string" Value="_selectedCategory" Label="Category" Variant="Variant.Outlined" Clearable="true"
                           ValueChanged="OnCategoryChanged">
                    @foreach (var cat in _categories)
                    {
                        <MudSelectItem Value="@cat">@cat</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudSelect T="string" Value="_selectedScope" Label="Scope" Variant="Variant.Outlined" Clearable="true"
                           ValueChanged="OnScopeChanged">
                    <MudSelectItem Value="@("mandatory")">Mandatory</MudSelectItem>
                    <MudSelectItem Value="@("recommended")">Recommended</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3" Class="d-flex align-center">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Showing @_filteredEntries.Count of @_entries.Count policies
                </MudText>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* Policy table *@
    <MudTable Items="_filteredEntries" Hover="true" Dense="true" Striped="true" Loading="_loading"
              FixedHeader="true" Height="600px">
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<PolicyCatalogEntryDto, object>(x => x.Name)">Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<PolicyCatalogEntryDto, object>(x => x.Category)">Category</MudTableSortLabel></MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Scope</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                <MudText Typo="Typo.body2" Style="font-weight:600;">@context.Name</MudText>
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">@TruncateText(context.DisplayName, 80)</MudText>
            </MudTd>
            <MudTd DataLabel="Category">
                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@context.Category</MudChip>
            </MudTd>
            <MudTd DataLabel="Type">
                <MudChip T="string" Size="Size.Small" Color="@GetTypeColor(context.DataType)" Variant="Variant.Filled">@context.DataType</MudChip>
            </MudTd>
            <MudTd DataLabel="Scope">
                @if (context.IsRecommended)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">Recommended</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Mandatory</MudChip>
                }
            </MudTd>
            <MudTd>
                @{ var entry = context; }
                <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small"
                               OnClick="@(async () => await ShowDetails(entry))" />
                <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Primary"
                               OnClick="@(async () => await AddToPolicySet(entry))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<PolicyCatalogEntryDto> _entries = [];
    private List<PolicyCatalogEntryDto> _filteredEntries = [];
    private List<string> _categories = [];
    private List<PolicySetDto> _policySets = [];
    private CatalogStatsDto? _stats;
    private bool _loading = true;
    private string _searchText = "";
    private string? _selectedCategory;
    private string? _selectedScope;

    // Import state
    private IBrowserFile? _selectedFile;
    private string _importVersion = "";
    private string _importMode = "full";
    private bool _importing;
    private CatalogImportResultDto? _importResult;
    private string? _importError;

    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var statsTask = Api.GetCatalogStatsAsync();
            var categoriesTask = Api.GetCatalogCategoriesAsync();
            var policySetsTask = Api.GetPoliciesAsync();

            await Task.WhenAll(statsTask, categoriesTask, policySetsTask);

            _stats = statsTask.Result;
            _categories = categoriesTask.Result;
            _policySets = policySetsTask.Result;

            if (_stats.TotalEntries > 0)
            {
                _entries = await Api.GetCatalogAsync();
                ApplyFilters();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load catalog: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnFileSelected(IBrowserFile file) => _selectedFile = file;

    private async Task ImportFromUrlAsync()
    {
        _importing = true;
        _importResult = null;
        _importError = null;
        StateHasChanged();

        try
        {
            _importResult = await Api.ImportCatalogFromUrlAsync(_importVersion, _importMode == "diff");

            // Reload data
            _stats = await Api.GetCatalogStatsAsync();
            _categories = await Api.GetCatalogCategoriesAsync();
            _entries = await Api.GetCatalogAsync();
            ApplyFilters();

            Snackbar.Add($"Successfully imported {_importResult.TotalParsed} policies!", Severity.Success);
        }
        catch (Exception ex)
        {
            _importError = ex.Message;
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _importing = false;
            StateHasChanged();
        }
    }

    private async Task ImportAsync()
    {
        if (_selectedFile is null) return;
        _importing = true;
        _importResult = null;
        _importError = null;
        StateHasChanged();

        try
        {
            using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 200 * 1024 * 1024);
            _importResult = await Api.ImportCatalogAsync(stream, _selectedFile.Name, _importVersion, _importMode == "diff");

            // Reload data
            _stats = await Api.GetCatalogStatsAsync();
            _categories = await Api.GetCatalogCategoriesAsync();
            _entries = await Api.GetCatalogAsync();
            ApplyFilters();

            Snackbar.Add($"Successfully imported {_importResult.TotalParsed} policies!", Severity.Success);
        }
        catch (Exception ex)
        {
            _importError = ex.Message;
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _importing = false;
            StateHasChanged();
        }
    }

    private void OnSearchChanged(string text)
    {
        _searchText = text;
        ApplyFilters();
    }

    private void OnCategoryChanged(string? val)
    {
        _selectedCategory = val;
        ApplyFilters();
    }

    private void OnScopeChanged(string? val)
    {
        _selectedScope = val;
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        _filteredEntries = _entries;

        if (!string.IsNullOrEmpty(_searchText))
            _filteredEntries = _filteredEntries.Where(e =>
                e.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                e.DisplayName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                e.Description.Contains(_searchText, StringComparison.OrdinalIgnoreCase)).ToList();

        if (!string.IsNullOrEmpty(_selectedCategory))
            _filteredEntries = _filteredEntries.Where(e => e.Category == _selectedCategory).ToList();

        if (_selectedScope == "mandatory")
            _filteredEntries = _filteredEntries.Where(e => !e.IsRecommended).ToList();
        else if (_selectedScope == "recommended")
            _filteredEntries = _filteredEntries.Where(e => e.IsRecommended).ToList();
    }

    private async Task ShowDetails(PolicyCatalogEntryDto entry)
    {
        var parameters = new DialogParameters<PolicyDetailsDialog>
        {
            { x => x.Entry, entry }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<PolicyDetailsDialog>(entry.Name, parameters, options);
    }

    private async Task AddToPolicySet(PolicyCatalogEntryDto entry)
    {
        var parameters = new DialogParameters<AddToPolicySetDialog>
        {
            { x => x.Entry, entry },
            { x => x.PolicySets, _policySets },
            { x => x.Api, Api }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AddToPolicySetDialog>($"Add {entry.Name}", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is AddToPolicySetResult addResult)
        {
            var value = entry.DataType switch
            {
                "Boolean" => addResult.Value is bool b ? (b ? "true" : "false") : addResult.Value.ToString()!,
                "Integer" => addResult.Value.ToString()!,
                "List" => addResult.Value is string s
                    ? System.Text.Json.JsonSerializer.Serialize(s.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                    : addResult.Value.ToString()!,
                _ => $"\"{addResult.Value}\""
            };

            Snackbar.Add($"Added {entry.Name} = {value} to \"{addResult.PolicySet.Name}\" (include in next version)", Severity.Success);
        }
    }

    private static string TruncateText(string text, int max) =>
        text.Length <= max ? text : text[..max] + "...";

    private static Color GetTypeColor(string dataType) => dataType switch
    {
        "Boolean" => Color.Success,
        "Integer" => Color.Info,
        "String" => Color.Warning,
        "Enum" => Color.Secondary,
        "List" => Color.Tertiary,
        _ => Color.Default
    };
}
