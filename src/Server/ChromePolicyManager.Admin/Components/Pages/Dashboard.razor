@page "/"
@rendermode InteractiveServer
@inject PolicyApiClient Api

<PageTitle>Dashboard - Chrome Policy Manager</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Dashboard</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_dashboard is not null)
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Devices" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h4">@_dashboard.TotalDevices</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total Devices</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" />
                    <MudText Typo="Typo.h4">@_dashboard.CompliantDevices</MudText>
                    <MudText Typo="Typo.body2">Compliant</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Large" Color="Color.Error" />
                    <MudText Typo="Typo.h4">@_dashboard.ErrorDevices</MudText>
                    <MudText Typo="Typo.body2">Errors</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.WifiOff" Size="Size.Large" Color="Color.Warning" />
                    <MudText Typo="Typo.h4">@_dashboard.OfflineDevices</MudText>
                    <MudText Typo="Typo.body2">Offline</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mt-6 mb-2">Recent Device Reports</MudText>
    <MudTable Items="@_dashboard.RecentReports" Hover="true" Striped="true" Dense="true" Elevation="1">
        <HeaderContent>
            <MudTh>Device</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Policy Hash</MudTh>
            <MudTh>Chrome</MudTh>
            <MudTh>Keys Written</MudTh>
            <MudTh>Last Contact</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.DeviceName</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
            </MudTd>
            <MudTd><MudText Typo="Typo.caption">@(context.AppliedPolicyHash?[..12] ?? "—")…</MudText></MudTd>
            <MudTd>@(context.ChromeVersion ?? "—")</MudTd>
            <MudTd>@context.PolicyKeysWritten</MudTd>
            <MudTd>@context.LastContact.ToLocalTime().ToString("g")</MudTd>
        </RowTemplate>
    </MudTable>
}
else
{
    <MudAlert Severity="Severity.Info">No monitoring data available yet. Devices will report in after the first remediation run.</MudAlert>
}

@code {
    private MonitoringDashboardDto? _dashboard;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try { _dashboard = await Api.GetDashboardAsync(); }
        catch { _dashboard = new MonitoringDashboardDto(); }
        finally { _loading = false; }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Compliant" => Color.Success,
        "PartiallyApplied" => Color.Warning,
        "Error" => Color.Error,
        _ => Color.Default
    };
}
