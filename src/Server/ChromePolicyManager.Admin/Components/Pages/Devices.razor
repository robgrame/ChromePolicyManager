@page "/devices"
@inject PolicyApiClient Api
@inject ToastService Toast

<PageTitle>Device Monitoring - Chrome Policy Manager</PageTitle>

<div class="page-header">
    <i class="bi bi-pc-display fs-3"></i>
    <h1 class="h3 mb-0">Device Monitoring</h1>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(_tab == 0 ? "active" : "")" @onclick="() => _tab = 0">
            <i class="bi bi-pc-display me-1"></i> All Devices
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_tab == 1 ? "active" : "")" @onclick="() => _tab = 1">
            <i class="bi bi-wifi-off me-1"></i> Offline
            @if (_offlineCount > 0) { <span class="badge text-bg-warning ms-1">@_offlineCount</span> }
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_tab == 2 ? "active" : "")" @onclick="() => _tab = 2">
            <i class="bi bi-exclamation-triangle me-1"></i> Errors
            @if (_errorCount > 0) { <span class="badge text-bg-danger ms-1">@_errorCount</span> }
        </button>
    </li>
</ul>

@if (_tab == 0)
{
    @if (_loadingDashboard)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
    }
    else if (_dashboard?.RecentReports.Any() == true)
    {
        <div class="input-group mb-3" style="max-width:360px;">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input class="form-control" placeholder="Search devices..." @bind="_searchString" @bind:event="oninput" />
        </div>
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Device</th><th>Status</th><th>Policy Hash</th><th>Chrome</th>
                            <th>OS</th><th>Model</th><th>Script</th><th>Keys</th><th>Last Contact</th><th>Err</th><th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Filtered(_dashboard.RecentReports))
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-1">
                                        <i class="bi bi-display text-@DeviceIcon(d)"></i>
                                        <strong>@d.DeviceName</strong>
                                    </div>
                                    <div class="small text-secondary mono">@Truncate(d.DeviceId, 8)…</div>
                                </td>
                                <td><span class="badge text-bg-@StatusBadge(d.Status)">@d.Status</span></td>
                                <td class="mono small" title="@(d.AppliedPolicyHash ?? "None")">@Truncate(d.AppliedPolicyHash, 12)</td>
                                <td>@(d.ChromeVersion ?? "—")</td>
                                <td>
                                    @(d.OsVersion ?? "—")
                                    @if (!string.IsNullOrEmpty(d.OsBuild)) { <div class="small text-secondary">Build @d.OsBuild</div> }
                                </td>
                                <td>@(string.IsNullOrEmpty(d.Manufacturer) && string.IsNullOrEmpty(d.Model) ? "—" : $"{d.Manufacturer} {d.Model}")</td>
                                <td class="mono small">@(d.ScriptVersion ?? "—")</td>
                                <td><span class="badge text-bg-success-subtle text-success">+@d.PolicyKeysWritten</span></td>
                                <td title="@d.LastContact.ToLocalTime().ToString("F")">@RelTime(d.LastContact)</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(d.Errors))
                                    {
                                        <i class="bi bi-exclamation-triangle-fill text-danger" title="@d.Errors"></i>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary" title="Trigger on-demand remediation"
                                            @onclick="() => TriggerDeviceRemediation(d)">
                                        <i class="bi bi-play-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No device reports yet. Devices will check in after the Proactive Remediation runs (scheduled hourly).
        </div>
    }
}
else if (_tab == 1)
{
    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <span>Devices that haven't checked in within:</span>
        <select class="form-select w-auto" @bind="_offlineHours" @bind:after="() => LoadOfflineDevices(_offlineHours)">
            <option value="4">4 hours</option>
            <option value="12">12 hours</option>
            <option value="24">24 hours</option>
            <option value="72">3 days</option>
            <option value="168">7 days</option>
        </select>
        <button class="btn btn-sm btn-outline-secondary" @onclick="() => LoadOfflineDevices(_offlineHours)">Refresh</button>
    </div>
    @if (_offlineDevices.Any())
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead><tr><th>Device</th><th>Last Contact</th><th>Last Status</th><th>Last Policy Hash</th></tr></thead>
                    <tbody>
                        @foreach (var d in _offlineDevices)
                        {
                            <tr>
                                <td><strong>@d.DeviceName</strong></td>
                                <td class="text-warning">@RelTime(d.LastContact)</td>
                                <td>@d.Status</td>
                                <td class="mono small">@Truncate(d.AppliedPolicyHash, 12)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-success">All devices have checked in recently.</div>
    }
}
else
{
    @if (_errorDevices.Any())
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead><tr><th>Device</th><th>Status</th><th>Error Details</th><th>Last Contact</th></tr></thead>
                    <tbody>
                        @foreach (var d in _errorDevices)
                        {
                            <tr>
                                <td><strong>@d.DeviceName</strong></td>
                                <td><span class="badge text-bg-danger">@d.Status</span></td>
                                <td class="small text-truncate" style="max-width:400px;">@d.Errors</td>
                                <td>@RelTime(d.LastContact)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-success">No devices reporting errors.</div>
    }
}

@code {
    private int _tab = 0;
    private MonitoringDashboardDto? _dashboard;
    private List<DeviceStateDto> _offlineDevices = [];
    private List<DeviceStateDto> _errorDevices = [];
    private bool _loadingDashboard = true;
    private string _searchString = "";
    private int _offlineHours = 24;
    private int _offlineCount;
    private int _errorCount;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadDashboard(), LoadOfflineDevices(24), LoadErrors());
    }

    private async Task LoadDashboard()
    {
        _loadingDashboard = true;
        try { _dashboard = await Api.GetDashboardAsync(); }
        catch (Exception ex) { Toast.Error($"Error: {ex.Message}"); }
        finally { _loadingDashboard = false; }
    }

    private async Task LoadOfflineDevices(int hours)
    {
        _offlineHours = hours;
        try
        {
            _offlineDevices = await Api.GetOfflineDevicesAsync(hours);
            _offlineCount = _offlineDevices.Count;
        }
        catch { _offlineDevices = []; }
    }

    private async Task LoadErrors()
    {
        try
        {
            _errorDevices = await Api.GetErrorDevicesAsync();
            _errorCount = _errorDevices.Count;
        }
        catch { _errorDevices = []; }
    }

    private IEnumerable<DeviceStateDto> Filtered(IEnumerable<DeviceStateDto> items) =>
        string.IsNullOrWhiteSpace(_searchString)
            ? items
            : items.Where(d =>
                d.DeviceName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                d.DeviceId.Contains(_searchString, StringComparison.OrdinalIgnoreCase));

    private static string StatusBadge(string status) => status switch
    {
        "Compliant" => "success",
        "PartiallyApplied" => "warning",
        "Error" => "danger",
        _ => "secondary"
    };

    private static string DeviceIcon(DeviceStateDto d)
    {
        if ((DateTime.UtcNow - d.LastContact).TotalHours > 24) return "warning";
        return d.Status == "Compliant" ? "success" : "danger";
    }

    private static string RelTime(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;
        if (diff.TotalMinutes < 5) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }

    private static string Truncate(string? value, int maxLength)
    {
        if (string.IsNullOrEmpty(value)) return "—";
        return value.Length <= maxLength ? value : value[..maxLength] + "…";
    }

    private async Task TriggerDeviceRemediation(DeviceStateDto device)
    {
        try
        {
            var result = await Api.TriggerDeviceRemediationAsync(device.DeviceId);
            if (result.CommandsFailed > 0) Toast.Warning($"{device.DeviceName}: {result.Message}");
            else Toast.Success($"{device.DeviceName}: {result.Message}");
        }
        catch (Exception ex)
        {
            Toast.Error($"Error triggering remediation for {device.DeviceName}: {ex.Message}");
        }
    }
}
