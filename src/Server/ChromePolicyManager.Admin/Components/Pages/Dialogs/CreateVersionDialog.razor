@inject PolicyApiClient Api
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">New Version - @PolicySet?.Name</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_version" Label="Version" Required="true" Variant="Variant.Outlined"
                      Placeholder="e.g. 1.0.0" Class="mb-3" />
        
        <MudText Typo="Typo.subtitle2" Class="mb-1">Chrome Policy Settings</MudText>
        @if (_settingsCount > 0)
        {
            <MudAlert Severity="Severity.Success" Dense="true" Class="mb-2">
                @_settingsCount policies configured in this draft (added via catalog ➕ button)
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                Add policies from the Catalog page using the ➕ button, or edit the JSON below manually.
            </MudAlert>
        }
        <MudTextField @bind-Value="_settingsJson" Label="Settings JSON" Variant="Variant.Outlined"
                      Lines="12" Placeholder='{"PolicyName": value, ...}' Style="font-family: monospace;"
                      HelperText="Auto-populated from catalog additions. You can also edit manually." />
        
        @if (_warnings.Any())
        {
            <MudAlert Severity="Severity.Warning" Class="mt-2" Dense="true">
                <MudText Typo="Typo.caption">Warnings: @string.Join("; ", _warnings)</MudText>
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(_version) || string.IsNullOrWhiteSpace(_settingsJson))">
            Create Version
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public PolicySetDto? PolicySet { get; set; }

    private string _version = "";
    private string _settingsJson = "";
    private int _settingsCount;
    private List<string> _warnings = [];

    protected override void OnInitialized()
    {
        if (PolicySet?.Versions.Any() == true)
        {
            var latest = PolicySet.Versions.OrderByDescending(v => v.CreatedAt).First();
            _settingsJson = latest.SettingsJson;
            _settingsCount = CountSettings(latest.SettingsJson);
            // Suggest next version
            var parts = latest.Version.Split('.');
            if (parts.Length == 3 && int.TryParse(parts[2], out var patch))
                _version = $"{parts[0]}.{parts[1]}.{patch + 1}";
        }
    }

    private static int CountSettings(string json)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            return doc.RootElement.EnumerateObject().Count();
        }
        catch { return 0; }
    }

    private async Task Submit()
    {
        try
        {
            var result = await Api.CreateVersionAsync(PolicySet!.Id, _version, _settingsJson);
            _warnings = result.Validation?.Warnings ?? [];
            
            Snackbar.Add($"Version {_version} created (Status: Draft). Promote to activate.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
