@inject PolicyApiClient Api
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Create Assignment</MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            Assign a policy version to an Entra ID group. Lower priority numbers take precedence.
        </MudAlert>

        <MudTextField @bind-Value="_entraGroupId" Label="Entra Group ID" Required="true" Variant="Variant.Outlined"
                      Placeholder="GUID of the Entra security group" Class="mb-3" />
        <MudTextField @bind-Value="_groupName" Label="Group Display Name" Required="true" Variant="Variant.Outlined"
                      Placeholder="e.g. MSLABS - Test" Class="mb-3" />
        <MudTextField @bind-Value="_policySetVersionId" Label="Policy Version ID" Required="true" Variant="Variant.Outlined"
                      Placeholder="GUID of the active policy version" Class="mb-3" />
        <MudNumericField @bind-Value="_priority" Label="Priority" Variant="Variant.Outlined" Min="1" Max="9999"
                         HelperText="Lower number = higher priority (wins on conflict)" Class="mb-3" />
        <MudSelect @bind-Value="_scope" Label="Scope" Variant="Variant.Outlined"
                   HelperText="Mandatory → HKLM\...\Chrome, Recommended → ...\Chrome\Recommended">
            <MudSelectItem Value="0">Mandatory</MudSelectItem>
            <MudSelectItem Value="1">Recommended</MudSelectItem>
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit"
                   Disabled="@(!IsValid)">Create Assignment</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private string _entraGroupId = "";
    private string _groupName = "";
    private string _policySetVersionId = "";
    private int _priority = 100;
    private int _scope = 0;

    private bool IsValid => !string.IsNullOrWhiteSpace(_entraGroupId) &&
                            !string.IsNullOrWhiteSpace(_groupName) &&
                            Guid.TryParse(_policySetVersionId, out _);

    private async Task Submit()
    {
        try
        {
            await Api.CreateAssignmentAsync(Guid.Parse(_policySetVersionId), _entraGroupId, _groupName, _priority, _scope);
            Snackbar.Add($"Assignment to '{_groupName}' created!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
